# NousResearch Proxy Configuration
# Copy to .env and fill in values

# Portal OAuth endpoints
NOUS_PORTAL_URL=https://portal.nousresearch.com
NOUS_INFERENCE_URL=https://inference-api.nousresearch.com/v1

# OAuth client config (public, no secret needed)
NOUS_CLIENT_ID=hermes-cli
NOUS_SCOPE=inference:mint_agent_key

# Proxy server
PROXY_HOST=0.0.0.0
PROXY_PORT=8090

# API keys for clients (comma-separated)
# Generated automatically on first run if empty
PROXY_API_KEYS=

# Data directory for token persistence
DATA_DIR=./data

# Logging
LOG_LEVEL=info
